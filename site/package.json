{
  "name": "simple-archiver-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src vite.config.ts vitest.config.ts",
    "lint:ci": "oxlint --deny-warnings src vite.config.ts vitest.config.ts",
    "format": "oxfmt src vite.config.ts vitest.config.ts",
    "fmt:check": "oxfmt --check src vite.config.ts vitest.config.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "jsdom": "29.1.1",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "tailwindcss": "^4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
